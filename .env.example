# ============================================================
# .env.example — 로컬 개발 전용 fallback 설정 파일
#
# 민감한 인증 정보(API Key, 비밀번호, Token)는
# OS 환경 변수로 설정하는 것을 권장합니다.
#
# OS 환경 변수가 없을 때만 이 파일의 값이 사용됩니다.
# 이 파일을 .env로 복사한 뒤 값을 채우세요:
#   cp .env.example .env
#
# .env는 .gitignore에 포함되어 있습니다. 절대 커밋하지 마세요.
# ============================================================

# Redmine 서버 주소
REDMINE_URL=https://redmine.example.com

# 수집 대상 프로젝트 — 아래 세 가지 방식 중 하나를 선택
# 방식 1: 단일 프로젝트 (fetch 기본 모드)
REDMINE_PROJECT=your_project_identifier
# 방식 2: 여러 특정 프로젝트 (쉼표 구분, fetch 명령어에서 자동 처리)
# REDMINE_PROJECTS=project-a,project-b,project-c
# 방식 3: 전체 프로젝트 → CLI 옵션 사용 (환경 변수 불필요)
#   fetch --all  또는  fetch-all

# Redmine 인증 — 아래 두 방식 중 하나만 설정
# 방식 1: API Key (권장) — Redmine > 내 계정 > API 액세스 키
REDMINE_API_KEY=your_redmine_api_key
# 방식 2: ID/PW (API Key를 발급받을 수 없는 경우)
# REDMINE_USERNAME=your_redmine_login_id
# REDMINE_PASSWORD=your_redmine_password

# GitHub 연결 정보
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repository-name

# 출력 디렉터리 (기본값: ./output)
OUTPUT_DIR=./output

# 캐시 디렉터리 (기본값: ./cache)
CACHE_DIR=./cache

# GitHub 파일 업로드 방식: API 또는 JGIT (기본값: API)
GITHUB_UPLOAD_METHOD=API

# Issue fetch 시 issues/{id}.md 파일도 저장할지 여부 (기본값: true)
REDMINE_ISSUE_MD_FETCH=true

# API 요청 간 지연 시간(ms) — Redmine fetch 및 GitHub upload(API 방식) 모두 적용 (기본값: 10)
# 예: 200이면 각 API 호출 전 0.2초 대기 → 초당 최대 5 req
REQUEST_DELAY_MS=10
